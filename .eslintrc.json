{
    "root": true,
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module",
        "ecmaFeatures": {
            "jsx": true
        }
    },
    "env": {
        "browser": true,
        "es2020": true,
        "node": true,
        "mocha": true
    },
    "extends": ["eslint:recommended"],
    "rules": {
        "consistent-this": ["error", "that"],
        "indent": ["error", 2, {"SwitchCase": 1}],
        "linebreak-style": ["error", "unix"],
        "semi": ["warn", "always"],
        "no-console": 0,
        "no-unused-vars": 0
    },
    "ignorePatterns": ["build/", "dist/", "node_modules/", "**/*.ts", "**/*.tsx"]
}
